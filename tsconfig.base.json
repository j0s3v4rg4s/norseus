{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@front/cn/components": ["libs/front/cn/components"],
      "@front/cn/components/*": ["libs/front/cn/components/*"],
      "@front/cn/hooks": ["libs/front/cn/hooks"],
      "@front/cn/lib": ["libs/front/cn/lib"],
      "@front/cn/utils": ["libs/front/cn/utils/index.ts"],
      "@front/core/classes": ["libs/front/core/classes/src/index.ts"],
      "@front/core/employee": ["libs/front/core/employee/src/index.ts"],
      "@front/core/facility": ["libs/front/core/facility/src/index.ts"],
      "@front/core/plans": ["libs/front/core/plans/src/index.ts"],
      "@front/core/profile": ["libs/front/core/profile/src/index.ts"],
      "@front/core/roles": ["libs/front/core/roles/src/index.ts"],
      "@front/core/services": ["libs/front/core/services/src/index.ts"],
      "@front/state/session": ["libs/front/state/session/src/index.ts"],
      "@front/supabase": ["libs/front/supabase/src/index.ts"],
      "@front/utils": ["libs/front/utils/src/index.ts"],
      "@models/classes": ["libs/models/src/classes/index.ts"],
      "@models/common": ["libs/models/src/common/index.ts"],
      "@models/facility": ["libs/models/src/facility/index.ts"],
      "@models/permissions": ["libs/models/src/permissions/index.ts"],
      "@models/plans": ["libs/models/src/plans/index.ts"],
      "@models/services": ["libs/models/src/services/index.ts"],
      "@models/user": ["libs/models/src/user/index.ts"],
      "@ui": ["libs/front/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
